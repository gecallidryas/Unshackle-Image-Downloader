# Default: text files normalized to LF in repo
*          text=auto eol=lf

# Windows script files should keep CRLF
*.bat      text eol=crlf
*.cmd      text eol=crlf
*.ps1      text eol=crlf

# Unixy scripts must be LF (shebang-friendly)
*.sh       text eol=lf

# Explicit LF for common web sources
*.js       text eol=lf
*.mjs      text eol=lf
*.ts       text eol=lf
*.json     text eol=lf
*.html     text eol=lf
*.css      text eol=lf