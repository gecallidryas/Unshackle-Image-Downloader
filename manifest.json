{
  "manifest_version": 3,
  "name": "Unshackle Image Downloader",
  "version": "1.0.1",
  "version_name": "1.0.0-prehk.0",
  "description": "Scan, filter, and download page images with advanced extraction, overlay cleanup, and ZIP export.",
  "default_locale": "en",
  "permissions": [
    "debugger",
    "sidePanel",
    "offscreen",
    "scripting",
    "activeTab",
    "tabs",
    "webNavigation",
    "storage",
    "downloads",
    "downloads.open",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "webRequest",
    "cookies",
    "alarms",
    "notifications",
    "unlimitedStorage",
    "contextMenus",
    "windows"
  ],
  "host_permissions": [],
  "optional_host_permissions": [
    "<all_urls>",
    "*://*.fbcdn.net/*",
    "*://*.cdninstagram.com/*"
  ],
  "action": {
    "default_title": "Unshackle"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-128.png",
    "48": "icons/icon-128.png",
    "128": "icons/icon-128.png"
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "bridge_inject.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page_blob_patch.js",
        "page_fetch_bridge.js",
        "overlay_keywords.md",
        "sites/site-registry.js",
        "sites/gigaviewer/module.js",
        "sites/speedbinb/module.js",
        "sites/bellaciao/module.js",
        "sites/madara/module.js",
        "sites/mangastream/module.js",
        "sites/foolslide/module.js",
        "adapters/hakuneko/delegates.js",
        "adapters/hakuneko/registry.js",
        "modes/manager.js",
        "content_manga.js",
        "offscreen.html",
        "offscreen.js",
        "hk-proxy.js",
        "vendor/hakuneko/shim/engine-shim.js",
        "vendor/hakuneko/runner/runner.mjs",
        "vendor/hakuneko/engine/ComicInfoGenerator.js",
        "vendor/hakuneko/engine/EbookGenerator.js",
        "vendor/hakuneko/index.json",
        "integrations/hakuneko/Bootstrap.mjs",
        "integrations/hakuneko/RequestAdapter.mjs",
        "integrations/hakuneko/StorageAdapter.mjs",
        "integrations/hakuneko/DownloadAdapter.mjs",
        "integrations/hakuneko/InterProcessCommunicationAdapter.mjs",
        "integrations/hakuneko/runtimeMessaging.mjs",
        "hakuneko-runtime/src/web/js/crypto-js.min.js",
        "help.html",
        "help.css",
        "help.js"
      ],
      "matches": [
        "<all_urls>",
        "file:///*"
      ]
    }
  ]
}