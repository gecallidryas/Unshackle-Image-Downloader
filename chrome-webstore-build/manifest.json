{
    "manifest_version": 3,
    "name": "Unshackle Image Downloader",
    "version": "1.0.1",
    "version_name": "1.0-beta",
    "description": "Scan, filter, and download page images with advanced extraction, overlay cleanup, and ZIP export.",
    "default_locale": "en",
    "permissions": [
        "cookies",
        "debugger",
        "sidePanel",
        "scripting",
        "tabs",
        "webNavigation",
        "storage",
        "downloads",
        "declarativeNetRequest",
        "declarativeNetRequestWithHostAccess",
        "webRequest",
        "alarms",
        "notifications",
        "unlimitedStorage",
        "contextMenus",
        "windows"
    ],
    "host_permissions": [],
    "optional_host_permissions": [
        "<all_urls>",
        "*://*.fbcdn.net/*",
        "*://*.cdninstagram.com/*"
    ],
    "action": {
        "default_title": "Unshackle"
    },
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "icons/icon-128.png",
        "48": "icons/icon-128.png",
        "128": "icons/icon-128.png"
    },
    "side_panel": {
        "default_path": "panel.html"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "bridge_inject.js"
            ],
            "run_at": "document_start",
            "all_frames": true
        },
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle",
            "all_frames": true
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "page_blob_patch.js",
                "page_fetch_bridge.js",
                "offscreen.html",
                "offscreen.js",
                "help.html",
                "help.css",
                "help.js"
            ],
            "matches": [
                "<all_urls>",
                "file:///*"
            ]
        }
    ]
}